{
  "name": "interrogating-blacks",
  "version": "1.0.0",
  "private": true,
  "bin": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "build:exe": "vite build && pkg . --targets node18-win-x64 --output release/InterrogatingBlacks.exe"
  },
  "pkg": {
    "assets": [
      "dist/**/*",
      "public/**/*",
      "node_modules/better-sqlite3/build/Release/*.node"
    ],
    "scripts": [
      "server/**/*.js"
    ]
  },
  "dependencies": {
    "axios": "^1.7.7",
    "better-sqlite3": "^11.3.0",
    "express": "^4.19.2",
    "he": "^1.2.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "pkg": "^5.8.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8"
  }
}
