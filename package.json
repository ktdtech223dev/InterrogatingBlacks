{
  "name": "interrogating-blacks",
  "version": "1.0.5",
  "description": "Multiplayer trivia game for the N Games launcher",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "electron": "electron .",
    "electron:dev": "vite build && electron .",
    "build:exe": "vite build && electron-builder --win portable --publish never"
  },
  "build": {
    "appId": "com.ngames.interrogatingblacks",
    "productName": "Interrogating Blacks",
    "files": [
      "electron/**/*",
      "server/**/*",
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "InterrogatingBlacks-${version}-portable.exe"
    },
    "portable": {
      "artifactName": "InterrogatingBlacks-${version}-portable.exe"
    },
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "axios": "^1.7.7",
    "better-sqlite3": "^12.9.0",
    "express": "^4.19.2",
    "he": "^1.2.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8"
  }
}
